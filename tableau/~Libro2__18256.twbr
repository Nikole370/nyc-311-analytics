      <column caption='Agency (dim agencia.csv)' datatype='string' name='[Agency (dim_agencia.csv)]' role='dimension' type='nominal' />
      <column caption='Borough (dim geo.csv)' datatype='string' name='[Borough (dim_geo.csv)]' role='dimension' type='nominal' />
      <column caption='Solicitudes 2025' datatype='integer' name='[Calculation_0577263327305728]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(IF YEAR([date]) = 2025 THEN 1 ELSE 0 END) }' />
      </column>
      <column caption='Solicitudes 2024' datatype='integer' name='[Calculation_0577263327395841]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(IF YEAR([date]) = 2024 THEN 1 ELSE 0 END) }' />
      </column>
      <column caption='Variación anual %' datatype='real' name='[Calculation_0577263327535106]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0577263327305728] - [Calculation_0577263327395841]) / [Calculation_0577263327395841]' />
      </column>
      <column caption='% de participación de una familia' datatype='real' default-format='p0.0%' name='[Calculation_0858735832412160]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Unique Key]) / TOTAL(COUNT([Unique Key]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Variación de quejas vs. año anterior' datatype='real' name='[Calculation_0858735833792514]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNT([Unique Key]) - LOOKUP(COUNT([Unique Key]), -1)) / ABS(LOOKUP(COUNT([Unique Key]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='SLA cumplido (binario)' datatype='string' name='[Calculation_0858735833903108]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [resolution_hours] &lt;= 72 THEN &quot;En tiempo&quot; ELSE &quot;Fuera de tiempo&quot; END' />
      </column>
      <column caption='Categoría de resolución' datatype='string' name='[Calculation_0858735833980933]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [resolution_hours] &lt;= 24 THEN &quot;1. &lt; 1 día&quot;&#13;&#10;ELSEIF [resolution_hours] &lt;= 72 THEN &quot;2. 1–3 días&quot;&#13;&#10;ELSEIF [resolution_hours] &lt;= 168 THEN &quot;3. 3–7 días&quot;&#13;&#10;ELSE &quot;4. Más de 7 días&quot;&#13;&#10;END' />
      </column>
      <column caption='Mes-Año' datatype='datetime' name='[Calculation_1254564964495360]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [date])' />
      </column>
      <column caption='% resuelto en menos de 1 día' datatype='real' default-format='p0.0%' name='[Calculation_2113008451899392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [resolution_hours] &lt;= 24 THEN 1 ELSE 0 END) / COUNT([Unique Key])' />
      </column>
      <column caption='% con más de 7 días' datatype='real' default-format='p0.0%' name='[Calculation_2113008452042753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [resolution_hours] &gt; 168 THEN 1 ELSE 0 END) / COUNT([Unique Key])' />
      </column>
      <column caption='Color KPI resuelto rápido' datatype='string' name='[Calculation_2113008453926914]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM(IF [resolution_hours] &lt;= 24 THEN 1 ELSE 0 END) / COUNT([Unique Key]) &gt;= 0.50&#13;&#10;THEN &quot;Verde&quot; ELSE &quot;Rojo&quot; END' />
      </column>
      <column caption='Color KPI rezago crítico' datatype='string' name='[Calculation_2113008454049795]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM(IF [resolution_hours] &gt; 168 THEN 1 ELSE 0 END) / COUNT([Unique Key]) &lt;= 0.10&#13;&#10;THEN &quot;Verde&quot; ELSE &quot;Rojo&quot; END' />
      </column>
