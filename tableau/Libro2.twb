            <column caption='Solicitudes 2025' datatype='integer' name='[Calculation_0577263327305728]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : SUM(IF YEAR([date]) = 2025 THEN 1 ELSE 0 END) }' />
            </column>
            <column caption='Variación de quejas vs. año anterior' datatype='real' name='[Calculation_0858735833792514]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(COUNT([Unique Key]) - LOOKUP(COUNT([Unique Key]), -1)) / ABS(LOOKUP(COUNT([Unique Key]), -1))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='integer' name='[Unique Key]' role='dimension' type='ordinal' />
